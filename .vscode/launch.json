{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Server",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/backend/target/debug/artbabo",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "preLaunchTask": "cargo build",
            "console": "integratedTerminal"
        },
        {
            "type": "msedge",
            "request": "launch",
            "name": "Client",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/frontend/src",
            "preLaunchTask": "start-npm",
            "postDebugTask": "stop-npm",
        }
    ],
    "compounds": [
        {
            "name": "Server/Client",
            "configurations": [
                "Server",
                "Client"
            ],
            "preLaunchTask": "start-dev-builds",
            "postDebugTask": "stop-npm",
            "stopAll": true
        }
    ]
}